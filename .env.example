# Database
DATABASE_URL="postgresql://user:password@localhost:5432/seointel_blog"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# AI Provider (anthropic or bedrock)
AI_PROVIDER="bedrock"

# Anthropic Direct API (if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=""

# AWS Bedrock (if AI_PROVIDER=bedrock)
BEDROCK_BLOG_MODEL="us.anthropic.claude-3-5-sonnet-20241022-v2:0"
AWS_BEDROCK_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Upstash Redis (optional for dev, required for prod)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# City Data APIs
CENSUS_API_KEY=""
BLS_API_KEY=""

# Default tenant for Phase 1
DEFAULT_TENANT_SLUG="seointel"
